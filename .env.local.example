# 智学云本地开发环境变量示例
#
# 用法：复制本文件为 .env.local，然后填入你自己的本地密码
#   copy .env.local.example .env.local
#
# ⚠️ 重要：
#   - .env.local 已被 .gitignore 拦截，永远不会被推上 GitHub
#   - 换电脑 / 重装系统后需要重新建
#   - 不要把 .env.local 的内容粘到聊天记录或截图中

# MySQL 用户名（默认 root）
DB_USERNAME=root

# MySQL 密码（请改成你自己的！）
DB_PASSWORD=please-set-your-password

# Redis 密码（本地开发一般为空）
REDIS_PASSWORD=
